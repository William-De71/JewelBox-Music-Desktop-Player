<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.william_de71.JewelBox</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>JewelBox</name>
  <summary>Écoutez votre bibliothèque musicale JewelBox</summary>
  <description>
    <p>
      Client de streaming pour le serveur JewelBox Music Library : parcourez
      votre collection d'albums, écoutez vos pistes, gérez vos playlists et
      laissez le mix dynamique tourner. Aucune bibliothèque locale : tout est
      lu depuis votre serveur sur le réseau local.
    </p>
  </description>
  <launchable type="desktop-id">io.github.william_de71.JewelBox.desktop</launchable>
  <developer id="io.github.william-de71">
    <name translate="no">William Deren</name>
  </developer>
  <url type="homepage">https://github.com/William-De71/JewelBox-Music-Desktop-Player</url>
  <url type="bugtracker">https://github.com/William-De71/JewelBox-Music-Desktop-Player/issues</url>
  <content_rating type="oars-1.1"/>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
  <requires>
    <display_length compare="ge">360</display_length>
    <internet>always</internet>
  </requires>
  <branding>
    <color type="primary" scheme_preference="light">#c061cb</color>
    <color type="primary" scheme_preference="dark">#613583</color>
  </branding>
  <releases>
    <release version="0.1.0" date="2026-07-19">
      <description>
        <p>Squelette initial de l'application.</p>
      </description>
    </release>
  </releases>
</component>
